# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Upload Configuration
MAX_CONTENT_LENGTH=104857600  # 100MB
UPLOAD_FOLDER=uploads

# TTS Configuration
FONT_PATH=models/msyh.ttc

# Video Configuration
BG_IMAGE=background.png
OUTPUT_FOLDER=data

# Cleanup Configuration
# VIDEO_RETENTION_HOURS=24
MAX_VIDEO_FILES=10  # Max number of video files to keep, set to -1 to disable cleanup

# STT Configuration (Whisper)
# Model sizes: tiny (39MB, fast), base (140MB, good), small (466MB, best)
# For 2GB RAM server: use 'tiny' or 'base'
# For 4GB+ RAM: use 'small' or 'medium'
# CPU-only servers: expect 10-60s per minute of audio depending on model
WHISPER_MODEL=small